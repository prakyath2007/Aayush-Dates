  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "node-cron": "^3.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
