{
  "name": "lovemarket-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
